# 🌟 CẤU HÌNH MÔI TRƯỜNG — YOUTUBE HD DOWNLOADER 🌟
# Copy file này thành .env rồi chỉnh sửa: cp .env.example .env

# 1. Thư mục lưu video tải về (mặc định: ./downloads trong thư mục dự án)
OUTPUT_DIR="./downloads"

# 2. (Tùy chọn) Đường dẫn Deno JS runtime để tăng độ ổn định khi giải mã JS của YouTube.
#    Để TRỐNG nếu máy chưa cài Deno — tool vẫn chạy bình thường.
#    Ví dụ macOS (Homebrew): /opt/homebrew/bin/deno
DENO_PATH=""

# 3. Số fragment tải SONG SONG cho link m3u8 (HLS) / DASH — càng cao càng nhanh.
#    Mặc định 5 (nhanh ~5–8× so với tải tuần tự). Tăng nếu mạng khỏe, giảm nếu bị chặn.
CONCURRENT_FRAGMENTS=5

# 4. Tải nguyên CHANNEL / PLAYLIST
#    CHANNEL_CONCURRENCY    : số VIDEO tải song song trong 1 channel (để thấp tránh bị chặn bot). Mặc định 3.
#    MAX_CHANNEL_VIDEOS     : trần CỨNG số video mỗi batch (áp cả khi không truyền `limit`). Mặc định 500.
#    MAX_CONCURRENT_CHANNELS: số batch channel chạy đồng thời (vượt -> API trả 429). Mặc định 2.
CHANNEL_CONCURRENCY=3
MAX_CHANNEL_VIDEOS=500
MAX_CONCURRENT_CHANNELS=2

# 5. Cấu hình máy chủ API
API_HOST="0.0.0.0"
API_PORT=8000
